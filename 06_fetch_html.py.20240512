def capture_screenshot(url, user_agent, filename):
    browser = await launch()
    page = await browser.newPage()
    await page.setUserAgent(user_agent)
    await page.goto(url, {'waitUntil': 'networkidle0'})
    await page.screenshot({'path': filename, 'fullPage': True})
    await browser.close()

    
def capture_screenshot_sync(url, user_agent, filename):
    try:
        # 最大スレッド数を5に設定
        executor = ThreadPoolExecutor(max_workers=100)
        
        #asyncio.get_event_loop().run_until_complete(capture_screenshot(url, user_agent, filename))
        # capture_screenshotを非同期で実行
        loop = asyncio.get_event_loop()
        future = loop.run_in_executor(executor, capture_screenshot, url, user_agent, filename)
        
        return True
    except Exception as e:
        logging.error(f"{datetime.now().isoformat()} - Error in capture_screenshot_sync function: {str(e)}")
        return False
    
    # メイン処理
for user_agent_name, user_agent_value in user_agents.items():
    get_website_data(user_agent_value)
