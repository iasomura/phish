def read_xml_from_gzip(gzip_file):
    try:
        with gzip.open(gzip_file, 'rb') as f:
            # gzipファイルからXMLデータを直接読み込む
            #tree = ET.parse(f)
            #root = tree.getroot()
            #return root
            xml_data = f.read()
            return xml_data

    except IOError as e:
        print(f"Error reading gzip file: {e}")
        return None
    

def normalize_url(url):
    parsed_url = urlparse(url)
    normalized_url = parsed_url.geturl()
    return normalized_url

def log_phish(url, status):
    current_time = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
    with open("phish_log.txt", "a") as f:
        f.write(f"{current_time} - URL: {url}, Status: {status}\n")

