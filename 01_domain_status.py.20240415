import os
import psycopg2
from psycopg2 import pool
import subprocess
from concurrent.futures import ThreadPoolExecutor

# データベースプールの設定
# Linux/macOS
#export DATABASE_URL=postgresql://postgres:asomura@localhost:5432/website_data

#DATABASE_URL = os.environ['DATABASE_URL']
#db_pool = pool.SimpleConnectionPool(1, 20, dsn=DATABASE_URL)

# データベース接続情報
db_host = 'localhost'
db_name = 'website_data'
db_user = 'postgres'
db_password = 'asomura'

# データベースプールの設定
db_pool = pool.SimpleConnectionPool(1, 20, 
                                   host=db_host,
                                   database=db_name,
                                   user=db_user,
                                   password=db_password)

def update_domain_status(domain_id, domain):
    try:
        # digコマンドの実行 (入力のサニタイズが必要)
        command = ['dig', domain, '+noall', '+answer', '+comments', '+stats']
        result = subprocess.run(command, capture_output=True, text=True)
        #print(result)
        output = result.stdout

        # NXDOMAIN または NOERROR の抽出
        status = None
        if 'NXDOMAIN' in output:
            status = 'NXDOMAIN'
        elif 'NOERROR' in output and 'ANSWER: 0,' in output:
            status = 'NOERROR'

        if status:
            # データベース接続の取得
            conn = db_pool.getconn()
            try:
                cur = conn.cursor()
                cur.execute("UPDATE website_data SET domain_status = %s WHERE id = %s;", (status, domain_id))
                conn.commit()
                print(f"Updated domain {domain} with status {status}")
            finally:
                db_pool.putconn(conn)
        else:
            print(f"No relevant status found for domain {domain}. Skipping update.{result}")

    except Exception as e:
        print(f"Error processing domain {domain}: {e}")

# データベースからドメインの取得
conn = db_pool.getconn()
try:
    cur = conn.cursor()
    cur.execute("SELECT id, domain FROM website_data WHERE domain_status IS NULL OR domain_status = '';")
    domains = cur.fetchall()
finally:
    db_pool.putconn(conn)

# スレッドプールの作成とタスクの割り当て
max_workers = os.cpu_count() * 2  # CPUコア数の2倍
with ThreadPoolExecutor(max_workers=max_workers) as executor:
    futures = [executor.submit(update_domain_status, domain_id, domain) for domain_id, domain in domains if domain]

# プールの終了
db_pool.closeall()
