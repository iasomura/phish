                conn.commit()
                
        cur.close()
        conn.close()

    except (Exception, psycopg2.DatabaseError) as error:
        logging.error(f"{datetime.now().isoformat()} - System Error: {str(error)}")

def fetch_website(url, user_agent):
    headers = {'User-Agent': user_agent}
    redirect_url = None
    html_content = None
    redirects = 0
    response = None  # responseを初期化

    try:
        while redirects <= MAX_REDIRECTS:
            try:
                response = requests.get(url, headers=headers, allow_redirects=False)
            except RequestException as e:
                logging.error(f"{datetime.now().isoformat()} - HTTP Error: {str(e)}")
                handle_http_error(e.response.status_code, url, user_agent)
                return None, None  # requests.get()が失敗した場合は終了
            
            response.raise_for_status() # HTTPエラーを発生させる

            if response.status_code == 200:
                html_content = response.text
                break
            elif response.status_code in (301, 302, 307, 308):
                redirect_url = response.headers.get('Location')
                url = redirect_url
                redirects += 1
            else:
                break

            if redirects > MAX_REDIRECTS:
                logging.error(f"{datetime.now().isoformat()} - Max redirects exceeded for {url}")
                break

    except RequestException as e:
        logging.error(f"{datetime.now().isoformat()} - HTTP Error: {str(e)}")
        handle_http_error(response.status_code, url, user_agent)
        # fetch_website関数でエラーが発生してもget_website_data関数のループは継続する
        return None, None

    except Exception as e:
        logging.error(f"{datetime.now().isoformat()} - System Error: {str(e)}")
        # fetch_website関数でエラーが発生してもget_website_data関数のループは継続する
        return None, None

    return html_content, redirect_url

def handle_http_error(status_code, url, user_agent):
    """
    HTTPエラーが発生した場合の処理を行う関数
    """
    if status_code == 404:
        # 404エラーの場合はリトライしない
        pass
    elif status_code == 500:
        # 500エラーの場合は5秒後にリトライ、最大3回まで
        retries = 3
        while retries > 0:
            time.sleep(5)
            html_content, redirect_url = fetch_website(url, user_agent)
            if html_content is not None:
                break
            retries -= 1
    elif status_code == 503:
        # 503エラーの場合は10秒後にリトライ、最大2回まで
        retries = 2
        while retries > 0:
            time.sleep(10)
            html_content, redirect_url = fetch_website(url, user_agent)
            if html_content is not None:
                break
            retries -= 1

# メイン処理


for user_agent_name, user_agent_value in user_agents.items():
    get_website_data(user_agent_value)

    
